# Copy this file to .env.local and add your keys. Do not commit .env.local or any file containing real API keys.
# App (client-exposed)
NEXT_PUBLIC_APP_TITLE=Weather Live

# OpenWeather: current weather, forecast, air pollution, geocoding
# Use OPENWEATHER_API_KEY for server-side; NEXT_PUBLIC_ for client current-weather if needed
OPENWEATHER_API_KEY=your_openweather_api_key
NEXT_PUBLIC_OPENWEATHER_API_KEY=your_openweather_api_key

# AI – server-only (use in API routes only)
GOOGLE_GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=your_openrouter_api_key

# Unsplash – server-only (dynamic weather backgrounds)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Optional: farming/agro, TTS
AGRO_API_KEY=your_agro_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
